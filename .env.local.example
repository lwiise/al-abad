# ---------------------------------------------------------------------------
# Supabase — copy this file to .env.local and fill from your Supabase project:
#   Project Settings → API
# .env.local is gitignored. NEVER commit real keys.
# ---------------------------------------------------------------------------

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Bypasses RLS. Used by admin writes and the
# create-admin script. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=
